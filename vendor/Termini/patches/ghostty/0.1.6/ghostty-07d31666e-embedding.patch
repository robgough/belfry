diff --git a/src/termio/Host.zig b/src/termio/Host.zig
new file mode 100644
index 000000000..8a1d43bd6
--- /dev/null
+++ b/src/termio/Host.zig
@@ -0,0 +1,128 @@
+//! Host implements a termio backend that forwards writes to an embedding
+//! host application instead of a pty-backed subprocess.
+const Host = @This();
+
+const std = @import("std");
+const Allocator = std.mem.Allocator;
+const renderer = @import("../renderer.zig");
+const terminal = @import("../terminal/main.zig");
+const termio = @import("../termio.zig");
+const ProcessInfo = @import("../pty.zig").ProcessInfo;
+
+pub const Config = struct {
+    userdata: ?*anyopaque,
+    write: *const fn (?*anyopaque, [*]const u8, usize) callconv(.c) void,
+};
+
+pub const ThreadData = struct {
+    pub fn deinit(self: *ThreadData, alloc: Allocator) void {
+        _ = self;
+        _ = alloc;
+    }
+};
+
+config: Config,
+
+pub fn init(cfg: Config) Host {
+    return .{ .config = cfg };
+}
+
+pub fn deinit(self: *Host) void {
+    _ = self;
+}
+
+pub fn initTerminal(self: *Host, term: *terminal.Terminal) void {
+    self.resize(.{
+        .columns = term.cols,
+        .rows = term.rows,
+    }, .{
+        .width = term.width_px,
+        .height = term.height_px,
+    }) catch {};
+}
+
+pub fn threadEnter(
+    self: *Host,
+    _: Allocator,
+    _: *termio.Termio,
+    td: *termio.Termio.ThreadData,
+) !void {
+    td.backend = .{ .host = .{} };
+    _ = self;
+}
+
+pub fn threadExit(self: *Host, td: *termio.Termio.ThreadData) void {
+    _ = self;
+    _ = td;
+}
+
+pub fn focusGained(
+    self: *Host,
+    td: *termio.Termio.ThreadData,
+    focused: bool,
+) !void {
+    _ = self;
+    _ = td;
+    _ = focused;
+}
+
+pub fn resize(
+    self: *Host,
+    _: renderer.GridSize,
+    _: renderer.ScreenSize,
+) !void {
+    _ = self;
+}
+
+pub fn queueWrite(
+    self: *Host,
+    alloc: Allocator,
+    td: *termio.Termio.ThreadData,
+    data: []const u8,
+    linefeed: bool,
+) !void {
+    _ = td;
+
+    if (!linefeed) {
+        self.config.write(self.config.userdata, data.ptr, data.len);
+        return;
+    }
+
+    var buf: std.ArrayListUnmanaged(u8) = .{};
+    defer buf.deinit(alloc);
+
+    try buf.ensureTotalCapacityPrecise(alloc, data.len);
+
+    for (data) |ch| {
+        if (ch != '\r') {
+            try buf.append(alloc, ch);
+            continue;
+        }
+
+        try buf.appendSlice(alloc, &.{ '\r', '\n' });
+    }
+
+    const slice = buf.items;
+    if (slice.len > 0) {
+        self.config.write(self.config.userdata, slice.ptr, slice.len);
+    }
+}
+
+pub fn childExitedAbnormally(
+    self: *Host,
+    gpa: Allocator,
+    t: *terminal.Terminal,
+    exit_code: u32,
+    runtime_ms: u64,
+) !void {
+    _ = self;
+    _ = gpa;
+    _ = t;
+    _ = exit_code;
+    _ = runtime_ms;
+}
+
+pub fn getProcessInfo(self: *Host, comptime info: ProcessInfo) ?ProcessInfo.Type(info) {
+    _ = self;
+    return null;
+}
